Options -Indexes

ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

# ---- Affiliate-Redirects (/r/...) 302, clickref = niederrhein-nord.de (AWIN 514869) ----
RewriteRule ^r/docmorris(-10euro)?/?$ https://www.awin1.com/cread.php?s=2490784&v=14485&q=372737&r=514869&clickref=niederrhein-nord.de [R=302,L,NE]
RewriteRule ^r/shop-apotheke(-rezept)?/?$ https://www.awin1.com/cread.php?s=3450028&v=13808&q=471107&r=514869&clickref=niederrhein-nord.de [R=302,L,NE]
RewriteRule ^r/mediherz(-gutscheine)?/?$ https://www.awin1.com/cread.php?s=2269210&v=11630&q=348918&r=514869&clickref=niederrhein-nord.de [R=302,L,NE]
RewriteRule ^r/medpex(-zuzahlungsfrei)?/?$ https://www.awin1.com/awclick.php?gid=447437&mid=36320&awinaffid=514869&linkid=3237938&clickref=niederrhein-nord.de [R=302,L,NE]
RewriteRule ^r/fliegende-pillen/?$ https://www.fliegende-pillen.de/?rd=start&p=232355&campaign=adcell&pk_campaign=adcell&bid=120210-78194-niederrhein-nord.de [R=302,L,NE]
RewriteRule ^r/parken-fliegen/?$ https://www.awin1.com/cread.php?awinmid=14793&awinaffid=514869&clickref=niederrhein-nord.de [R=302,L,NE]
  RewriteBase /

  # Canonical host: force HTTPS + www → https://www.niederrhein-nord.de
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^niederrhein-nord\.de$ [NC]
  RewriteRule ^ https://www.niederrhein-nord.de%{REQUEST_URI} [L,R=301]

  # === Legacy-WordPress → neuer Build (301) ===
  RewriteRule ^blog/?$ /news/ [L,R=301]
  RewriteRule ^entdecken-sie/?$ / [L,R=301]
  RewriteRule ^beste-hotels-kreis-kleve-2/?$ /beste-hotels-kreis-kleve/ [L,R=301]
  RewriteRule ^page/[0-9]+/?$ / [L,R=301]

  # === Alt-Gastbeiträge (off-topic, kein Niederrhein-Bezug) → thematisch nächste Seite (301) ===
  RewriteRule ^traumberuf-immobilienmakler/?$ /immobilien-niederrhein/ [L,R=301]
  RewriteRule ^wie-finde-ich-einen-guten-fliesenverleger/?$ /unternehmen-niederrhein/ [L,R=301]
  RewriteRule ^ausbildungsanforderungen-fuer-elektriker/?$ /unternehmen-niederrhein/ [L,R=301]
  RewriteRule ^wie-finden-sie-eine-umzugsfirma/?$ /unternehmen-niederrhein/ [L,R=301]
  RewriteRule ^der-umzug-rueckt-naeher/?$ /unternehmen-niederrhein/ [L,R=301]
  RewriteRule ^eine-kurze-geschichte-von-gin/?$ /kulinarischer-roadtrip/ [L,R=301]
  RewriteRule ^gps-hunde/?$ / [L,R=301]
  RewriteRule ^test/?$ / [L,R=301]

  # === Casino/Spam-Altlasten → 410 Gone (kein Linkjuice-Vererben) ===
  RewriteRule (betninja|bet-ninja|moro-spin|get-lucky|aruba-bet|casino-star|bet-wild|winpot|teaspins|vavada|casino-online|casino-su-internet|gokwebsites|gokwebsite|online-casinos|internet-casino|online-slots|sister-casino|entertainment-hub|esplora-il-mondo|siti-casino|migliori-casino|superior-casino|naj-) - [G,NC]

  # Serve pre-built HTML files directly
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L,QSA]
</IfModule>
