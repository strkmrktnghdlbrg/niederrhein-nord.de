---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import ContentImage from "../../../components/ContentImage.astro";
import RelatedItems from "../../../components/RelatedItems.astro";
import Stay22NearbyHotels from "../../../components/Stay22NearbyHotels.astro";
import GetYourGuideWidget from "../../../components/GetYourGuideWidget.astro";
import { sights } from "../../../data/sights";
import { sightsEn } from "../../../i18n/en/sights";
import { getDistrict } from "../../../data/districts";
import { districtsEn } from "../../../i18n/en/districts";
import { getCategory } from "../../../data/categories";
import { categoriesEn } from "../../../i18n/en/categories";
import { guides } from "../../../data/guides";
import { guidesEn } from "../../../i18n/en/guides";
import { getGygPlacement } from "../../../data/gyg";
import { city } from "../../../data/city";
import { t, tf } from "../../../i18n/ui";
import { homeUrl, indexUrl, detailUrl } from "../../../i18n/config";

export function getStaticPaths() {
  return sights.map((s) => ({
    params: { slug: sightsEn[s.slug].slug },
    props: { sight: s, en: sightsEn[s.slug] },
  }));
}

const { sight, en } = Astro.props;
const locale = "en";
const district = getDistrict(sight.district);
const districtEn = districtsEn[sight.district];
const priceLabel =
  sight.priceFrom === null ? t(locale, "detail.freeEntry") : tf(locale, "detail.priceFrom", { n: sight.priceFrom });
// Travel planners that feature this sight
const sightGuides = guides.filter((g) =>
  g.days.some((d) => d.slots.some((s) => s.sightSlug === sight.slug)),
);

const schema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  name: en.name,
  description: en.shortDesc,
  address: { "@type": "PostalAddress", addressLocality: city.name, addressCountry: city.countryCode },
  geo: { "@type": "GeoCoordinates", latitude: sight.coordinates[0], longitude: sight.coordinates[1] },
  ...(en.openingHours && { openingHours: en.openingHours }),
  ...(sight.websiteUrl && { url: sight.websiteUrl }),
};
---

<BaseLayout
  title={en.name}
  description={en.shortDesc}
  locale={locale}
  alternateUrls={{ de: `/sehenswuerdigkeiten/${sight.slug}/`, en: detailUrl("sights", en.slug, locale) }}
>
  <article class="container-page py-12">
    <Breadcrumbs locale={locale} items={[
      { label: t(locale, "nav.home"), href: homeUrl(locale) },
      { label: t(locale, "nav.sights"), href: indexUrl("sights", locale) },
      { label: en.name },
    ]} />

    <div class="grid lg:grid-cols-[2fr_1fr] gap-10 mb-12">
      <div>
        <p class="eyebrow mb-3">{en.type}{district && ` · ${districtEn?.name ?? district.name}`}</p>
        <h1 class="text-4xl sm:text-6xl font-medium tracking-tight mb-6" style="color: var(--color-text);">{en.name}</h1>
        <p class="text-lg leading-relaxed mb-6" style="color: var(--color-text-body);">{en.longDesc}</p>

        {en.sections && en.sections.length > 0 && (
          <div class="mb-8 space-y-6">
            {en.sections.map((s) => (
              <section>
                <h2 class="text-2xl font-semibold tracking-tight mb-3" style="color: var(--color-text);">{s.h}</h2>
                <p class="leading-relaxed" style="color: var(--color-text-body);">{s.p}</p>
              </section>
            ))}
          </div>
        )}

        <div class="flex flex-wrap gap-2 mb-6">
          <span class="pill-accent">{priceLabel}</span>
          {en.openingHours && <span class="pill">{en.openingHours}</span>}
          {sight.categories.map((c) => {
            const cat = getCategory(c);
            const catEn = categoriesEn[c];
            return cat ? <a href={detailUrl("categories", catEn?.slug ?? cat.slug, locale)} class="pill">{catEn?.name ?? cat.name}</a> : null;
          })}
        </div>

        {sight.websiteUrl && (
          <a href={sight.websiteUrl} rel="nofollow noopener" target="_blank" class="btn-primary">
            {t(locale, "detail.officialWebsite")}
          </a>
        )}
      </div>

      <aside class="aspect-[4/3] lg:aspect-auto lg:min-h-[320px] overflow-hidden" style="border-radius: var(--radius-card);">
        <ContentImage
          imgKey={sight.imageKey}
          fallbackHue={sight.imageHue}
          fallbackLabel={en.name}
          loading="eager"
          showCredit
          sizes="(min-width: 1024px) 33vw, 100vw"
        />
      </aside>
    </div>

    {district && districtEn && (
      <div class="my-12 p-6 border" style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-card);">
        <p class="eyebrow mb-2">{t(locale, "detail.inDistrict")}</p>
        <h2 class="text-xl font-semibold mb-2" style="color: var(--color-text);">{districtEn.name}</h2>
        <p class="text-sm mb-3" style="color: var(--color-text-body);">{districtEn.shortDesc}</p>
        <a href={detailUrl("districts", districtEn.slug, locale)} class="link-accent text-sm">{t(locale, "detail.districtHub")}</a>
      </div>
    )}

    {sightGuides.length > 0 && (
      <section class="section border-t" style="border-color: var(--color-border);">
        <h2 class="text-3xl font-semibold mb-6" style="color: var(--color-text);">Part of these travel planners</h2>
        <ul class="space-y-3">
          {sightGuides.map((g) => (
            <li>
              <a href={detailUrl("guides", guidesEn[g.slug].slug, locale)} class="text-lg font-medium underline" style="color: var(--color-link, var(--color-text));">{guidesEn[g.slug].title}</a>
              <p class="text-sm" style="color: var(--color-text-body);">{guidesEn[g.slug].shortDesc}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <GetYourGuideWidget placement={getGygPlacement(`sight:${sight.slug}`)} />

    <Stay22NearbyHotels lat={sight.coordinates[0]} lng={sight.coordinates[1]} near={en.name} limit={4} />

    <RelatedItems district={sight.district} excludeSlug={sight.slug} type="sights" locale={locale} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline></script>
  </article>
</BaseLayout>
