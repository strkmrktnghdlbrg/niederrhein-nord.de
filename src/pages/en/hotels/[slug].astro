---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import ContentImage from "../../../components/ContentImage.astro";
import BookingCTA from "../../../components/BookingCTA.astro";
import RelatedItems from "../../../components/RelatedItems.astro";
import Stay22NearbyHotels from "../../../components/Stay22NearbyHotels.astro";
import { hotels } from "../../../data/hotels";
import { getDistrict } from "../../../data/districts";
import { guides } from "../../../data/guides";
import { city } from "../../../data/city";
import { hotelsEn } from "../../../i18n/en/hotels";
import { guidesEn } from "../../../i18n/en/guides";
import { districtsEn } from "../../../i18n/en/districts";
import { detailUrl, homeUrl, indexUrl } from "../../../i18n/config";
import { t, tf } from "../../../i18n/ui";

export function getStaticPaths() {
  return hotels.map((h) => ({
    params: { slug: hotelsEn[h.slug].slug },
    props: { hotel: h, en: hotelsEn[h.slug] },
  }));
}

const locale = "en" as const;
const { hotel, en } = Astro.props;
const district = getDistrict(hotel.district);
const districtEn = districtsEn[hotel.district];
const districtName = districtEn?.name ?? district?.name ?? hotel.district;
const districtShortDesc = districtEn?.shortDesc ?? district?.shortDesc ?? "";
const stars = "*".repeat(hotel.stars);
// Travel planners that reference this hotel
const hotelGuides = guides.filter((g) =>
  g.days.some((d) => d.slots.some((s) => s.hotelSlug === hotel.slug)),
);

const schema = {
  "@context": "https://schema.org",
  "@type": "Hotel",
  name: en.name,
  description: en.shortDesc,
  starRating: { "@type": "Rating", ratingValue: hotel.stars },
  aggregateRating: { "@type": "AggregateRating", ratingValue: hotel.rating, reviewCount: hotel.reviews, bestRating: 10 },
  priceRange: `EUR ${hotel.priceFrom}+`,
  address: { "@type": "PostalAddress", addressLocality: city.name, addressCountry: city.countryCode },
};
---

<BaseLayout
  title={en.name}
  description={en.shortDesc}
  locale={locale}
  alternateUrls={{
    de: detailUrl("hotels", hotel.slug, "de"),
    en: detailUrl("hotels", en.slug, "en"),
  }}
>
  <article class="container-page py-12">
    <Breadcrumbs items={[
      { label: t(locale, "nav.home"), href: homeUrl(locale) },
      { label: t(locale, "nav.hotels"), href: indexUrl("hotels", locale) },
      { label: en.name },
    ]} locale={locale} />

    <div class="grid lg:grid-cols-[2fr_1fr] gap-10 mb-12">
      <div>
        <p class="eyebrow mb-3">{stars} &middot; {districtName}</p>
        <h1 class="text-4xl sm:text-6xl font-medium tracking-tight mb-3" style="color: var(--color-text);">{en.name}</h1>
        <div class="flex items-center gap-3 mb-6">
          <span class="text-2xl font-bold" style="color: var(--color-accent);">{hotel.rating.toFixed(1)}</span>
          <span class="text-sm" style="color: var(--color-text-muted);">{tf(locale, "detail.guestReviews", { n: hotel.reviews })}</span>
          {hotel.guestFavorite && <span class="pill-accent">{t(locale, "detail.guestFavorite")}</span>}
        </div>
        <p class="text-lg leading-relaxed mb-6" style="color: var(--color-text-body);">{en.longDesc}</p>

        {en.sections && en.sections.length > 0 && (
          <div class="mb-8 space-y-6">
            {en.sections.map((s) => (
              <section>
                <h2 class="text-2xl font-semibold tracking-tight mb-3" style="color: var(--color-text);">{s.h}</h2>
                <p class="leading-relaxed" style="color: var(--color-text-body);">{s.p}</p>
              </section>
            ))}
          </div>
        )}

        <div class="flex flex-wrap gap-2 mb-6">
          {en.amenities.map((a) => <span class="pill">{a}</span>)}
        </div>
      </div>

      <aside class="space-y-5">
        <div class="aspect-[4/3] overflow-hidden" style="border-radius: var(--radius-card);">
          <ContentImage
            imgKey={`district:${hotel.district}`}
            fallbackHue={hotel.imageHue}
            fallbackLabel={en.name}
            loading="eager"
            showCredit
            sizes="(min-width: 1024px) 33vw, 100vw"
          />
        </div>
        <BookingCTA hotel={hotel} locale={locale} />
      </aside>
    </div>

    {district && (
      <div class="my-12 p-6 border" style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-card);">
        <p class="eyebrow mb-2">{t(locale, "detail.district")}</p>
        <h2 class="text-xl font-semibold mb-2" style="color: var(--color-text);">{districtName}</h2>
        <p class="text-sm mb-3" style="color: var(--color-text-body);">{districtShortDesc}</p>
        <a href={detailUrl("districts", districtEn?.slug ?? district.slug, locale)} class="link-accent text-sm">{t(locale, "detail.districtHub")}</a>
      </div>
    )}

    {hotelGuides.length > 0 && (
      <section class="section border-t" style="border-color: var(--color-border);">
        <h2 class="text-3xl font-semibold mb-6" style="color: var(--color-text);">Part of these travel planners</h2>
        <ul class="space-y-3">
          {hotelGuides.map((g) => (
            <li>
              <a href={detailUrl("guides", guidesEn[g.slug].slug, locale)} class="text-lg font-medium underline" style="color: var(--color-link, var(--color-text));">{guidesEn[g.slug].title}</a>
              <p class="text-sm" style="color: var(--color-text-body);">{guidesEn[g.slug].shortDesc}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    {district && (
      <Stay22NearbyHotels
        lat={district.coordinates[0]}
        lng={district.coordinates[1]}
        near={districtName}
        radius={2500}
        limit={4}
      />
    )}

    <RelatedItems district={hotel.district} type="sights" locale={locale} />

    <RelatedItems district={hotel.district} type="restaurants" locale={locale} />

    <RelatedItems district={hotel.district} excludeSlug={hotel.slug} type="hotels" locale={locale} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline></script>
  </article>
</BaseLayout>
