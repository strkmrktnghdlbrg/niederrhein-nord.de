---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import GetYourGuideWidget from "../../../components/GetYourGuideWidget.astro";
import { events, isUpcoming } from "../../../data/events";
import { eventsEn } from "../../../i18n/en/events";
import { getGygPlacement } from "../../../data/gyg";
import { t, tf } from "../../../i18n/ui";
import { homeUrl, indexUrl } from "../../../i18n/config";

const locale = "en" as const;
const startOf = (e: (typeof events)[number]) => e.eventStart ?? e.checkin;
const endOf = (e: (typeof events)[number]) => e.eventEnd ?? e.checkout;
const sorted = [...events].sort((a, b) => new Date(startOf(a)).getTime() - new Date(startOf(b)).getTime());
const fmtRange = (ci?: string, co?: string) => {
  if (!ci || !co) return "";
  const a = new Date(ci).toLocaleDateString("en-US", { day: "2-digit", month: "long", year: "numeric" });
  const b = new Date(co).toLocaleDateString("en-US", { day: "2-digit", month: "long", year: "numeric" });
  return tf(locale, "events.range", { from: a, to: b });
};
---

<BaseLayout
  title={t(locale, "events.indexTitle")}
  description={t(locale, "events.indexDescription")}
  locale={locale}
  alternateUrls={{ de: indexUrl("events", "de"), en: indexUrl("events", "en") }}
>
  <div class="container-page py-12">
    <Breadcrumbs locale={locale} items={[{label: t(locale, "nav.home"), href: homeUrl(locale)}, {label: t(locale, "nav.events")}]} />
    <header class="mb-12 max-w-3xl">
      <p class="eyebrow mb-3">{t(locale, "events.eyebrow")}</p>
      <h1 class="text-4xl sm:text-6xl font-medium tracking-tight mb-4" style="color: var(--color-text);">{t(locale, "events.heading")}</h1>
      <p class="text-lg" style="color: var(--color-text-body);">
        {t(locale, "events.intro")}
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {sorted.map((e) => {
        const en = eventsEn[e.slug];
        const past = !isUpcoming(e);
        return (
          <a href={indexUrl("hotels", locale)} class="card group block p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="pill-accent">{en.eyebrow}</span>
              {past && <span class="pill">{t(locale, "events.past")}</span>}
            </div>
            <h2 class="text-xl font-semibold mb-2" style="color: var(--color-text);">{en.title}</h2>
            <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-body);">{en.intro}</p>
            <p class="text-xs mb-3" style="color: var(--color-text-muted);">{fmtRange(startOf(e), endOf(e))}</p>
            <span class="link-accent text-sm">{t(locale, "events.hotelsForDate")}</span>
          </a>
        );
      })}
    </div>

    <GetYourGuideWidget placement={getGygPlacement("page:events-index")} />
  </div>
</BaseLayout>
