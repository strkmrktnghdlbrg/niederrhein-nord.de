---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import NewsCard from "../../../components/NewsCard.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { news } from "../../../data/news";
import { features } from "../../../data/features";
import { homeUrl, indexUrl } from "../../../i18n/config";
import { t } from "../../../i18n/ui";

const locale = "en" as const;

if (!features.news.enabled) return Astro.redirect("/en/", 302);
const sorted = [...news].sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());
---

<BaseLayout
  title={t(locale, "news.title")}
  description={t(locale, "news.metaDescription")}
  locale={locale}
  alternateUrls={{ de: indexUrl("news", "de"), en: indexUrl("news", "en") }}
>
  <div class="container-page py-12">
    <Breadcrumbs
      locale={locale}
      items={[{ label: t(locale, "nav.home"), href: homeUrl(locale) }, { label: t(locale, "nav.news") }]}
    />
    <header class="mb-12">
      <p class="eyebrow mb-3">{t(locale, "news.eyebrow")}</p>
      <h1 class="text-4xl sm:text-6xl font-medium tracking-tight mb-4" style="color: var(--color-text);">{t(locale, "news.heading")}</h1>
      <p class="text-lg max-w-3xl" style="color: var(--color-text-body);">
        {t(locale, "news.intro")}
      </p>
    </header>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {sorted.map((n) => <NewsCard item={n} locale={locale} />)}
    </div>
  </div>
</BaseLayout>
