---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import HueGradient from "../../components/HueGradient.astro";
import SightCard from "../../components/SightCard.astro";
import HotelCard from "../../components/HotelCard.astro";
import RestaurantCard from "../../components/RestaurantCard.astro";
import Stay22NearbyHotels from "../../components/Stay22NearbyHotels.astro";
import GetYourGuideWidget from "../../components/GetYourGuideWidget.astro";
import { districts, getDistrict } from "../../data/districts";
import { sightsByDistrict } from "../../data/sights";
import { topHotelsByDistrict } from "../../data/hotels";
import { restaurantsByDistrict } from "../../data/restaurants";
import { getGygPlacement } from "../../data/gyg";
import { districtsEn } from "../../i18n/en/districts";
import { detailUrl } from "../../i18n/config";

export function getStaticPaths() {
  return districts.map((d) => ({ params: { slug: d.slug } }));
}

const { slug } = Astro.params;
const district = getDistrict(slug!);
if (!district) return Astro.redirect("/404");

const sightItems = sightsByDistrict(district.slug);
const hotelItems = topHotelsByDistrict(district.slug, 8);
const restItems = restaurantsByDistrict(district.slug).slice(0, 8);

const alternateUrls = {
  de: `/bezirke/${district.slug}/`,
  en: detailUrl("districts", districtsEn[district.slug].slug, "en"),
};

// Vertiefende Hotel-Landingpages je Stadtteil (aus dem Bestand übernommen)
const legacyHotelPages: Record<string, { url: string; label: string }> = {
  mitte: { url: "/hotels-mitte/", label: "Alle Hotels am Niederrhein Mitte im Detail" },
  sued: { url: "/hotels-sued/", label: "Alle Hotels am Niederrhein-Süd im Detail" },
  ruhrort: { url: "/hotels-ruhrort/", label: "Hotels in Ruhrort & Homberg im Detail" },
  homberg: { url: "/hotels-ruhrort/", label: "Hotels in Ruhrort & Homberg im Detail" },
  meiderich: { url: "/hotels-meiderich/", label: "Hotels in Meiderich & Beeck im Detail" },
  beeck: { url: "/hotels-meiderich/", label: "Hotels in Meiderich & Beeck im Detail" },
  rheinhausen: { url: "/hotels-rheinhausen/", label: "Alle Hotels in Rheinhausen im Detail" },
};
const legacyHotels = legacyHotelPages[district.slug];
---

<BaseLayout title={district.name} description={district.shortDesc} alternateUrls={alternateUrls}>
  <div class="container-page py-12">
    <Breadcrumbs items={[{label: "Start", href: "/"}, {label: "Bezirke", href: "/bezirke/"}, {label: district.name}]} />

    <header class="grid lg:grid-cols-[2fr_1fr] gap-10 mb-12">
      <div>
        <p class="eyebrow mb-3">Bezirk</p>
        <h1 class="text-4xl sm:text-6xl font-medium tracking-tight mb-6" style="color: var(--color-text);">{district.name}</h1>
        <p class="text-lg leading-relaxed mb-6" style="color: var(--color-text-body);">{district.longDesc}</p>
        <div class="flex flex-wrap gap-2">
          {district.characterTags.map((t) => <span class="pill">{t}</span>)}
        </div>
      </div>
      <div class="aspect-[4/3] overflow-hidden" style="border-radius: var(--radius-card);">
        <HueGradient hue={district.hue} label={district.name} />
      </div>
    </header>

    {sightItems.length > 0 && (
      <section class="section">
        <h2 class="text-3xl font-semibold mb-6" style="color: var(--color-text);">Sehenswuerdigkeiten in {district.name}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {sightItems.map((s) => <SightCard sight={s} />)}
        </div>
      </section>
    )}

    {hotelItems.length > 0 && (
      <section class="section border-t" style="border-color: var(--color-border);">
        <h2 class="text-3xl font-semibold mb-6" style="color: var(--color-text);">Hotels in {district.name}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {hotelItems.map((h) => <HotelCard hotel={h} />)}
        </div>
        {legacyHotels && (
          <p class="mt-6">
            <a class="link-accent text-base font-medium" href={legacyHotels.url}>{legacyHotels.label} &rarr;</a>
          </p>
        )}
      </section>
    )}

    {legacyHotels && hotelItems.length === 0 && (
      <section class="section border-t" style="border-color: var(--color-border);">
        <h2 class="text-3xl font-semibold mb-4" style="color: var(--color-text);">Hotels in {district.name}</h2>
        <p class="text-lg mb-4" style="color: var(--color-text-body);">Übernachtungstipps und eine ausführliche Hotelübersicht für diesen Stadtteil findest du hier:</p>
        <a class="link-accent text-base font-medium" href={legacyHotels.url}>{legacyHotels.label} &rarr;</a>
      </section>
    )}

    {restItems.length > 0 && (
      <section class="section border-t" style="border-color: var(--color-border);">
        <h2 class="text-3xl font-semibold mb-6" style="color: var(--color-text);">Restaurants in {district.name}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {restItems.map((r) => <RestaurantCard restaurant={r} />)}
        </div>
      </section>
    )}

    <GetYourGuideWidget placement={getGygPlacement(`district:${district.slug}`)} />

    <Stay22NearbyHotels
      lat={district.coordinates[0]}
      lng={district.coordinates[1]}
      near={district.name}
      radius={2500}
      limit={4}
    />
  </div>
</BaseLayout>
