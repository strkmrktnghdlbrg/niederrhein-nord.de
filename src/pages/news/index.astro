---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsCard from "../../components/NewsCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { news } from "../../data/news";
import { features } from "../../data/features";
import { indexUrl } from "../../i18n/config";
import legacyArticles from "../../data/legacy-articles.json";

if (!features.news.enabled) return Astro.redirect("/", 302);
const sorted = [...news].sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());
---

<BaseLayout title="Niederrhein-Magazin" description="Aktuelles vom Niederrhein — Natur, Genuss und Kultur: Wildgänse in den Rheinauen, Spargel- & Erdbeerzeit, Römerstadt Xanten und Schloss Moyland." alternateUrls={{ de: indexUrl("news", "de"), en: indexUrl("news", "en") }}>
  <div class="container-page py-12">
    <Breadcrumbs items={[{label: "Start", href: "/"}, {label: "News"}]} />
    <header class="mb-12">
      <p class="eyebrow mb-3">Stadt &middot; Wirtschaft &middot; Kultur</p>
      <h1 class="text-4xl sm:text-6xl font-medium tracking-tight mb-4" style="color: var(--color-text);">Niederrhein-Magazin</h1>
      <p class="text-lg max-w-3xl" style="color: var(--color-text-body);">
        Kuratierte Beiträge rund um Natur, Genuss und Kultur am Niederrhein: Wildgänse, Spargel- & Erdbeerzeit, Radsaison und die Highlights von Xanten bis Kevelaer. Kurze Zusammenfassungen mit Verweis zur Originalquelle.
      </p>
    </header>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {sorted.map((n) => <NewsCard item={n} />)}
    </div>

    <section class="mt-16 pt-10 border-t" style="border-color: var(--color-border);">
      <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight mb-2" style="color: var(--color-text);">Ratgeber &amp; Themen vom Niederrhein</h2>
      <p class="text-base mb-6 max-w-3xl" style="color: var(--color-text-body);">
        Hintergründe und Tipps rund um Natur, Kultur, Genuss und Aktivurlaub am nördlichen Niederrhein.
      </p>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-2.5">
        {legacyArticles.map((a) => (
          <li><a href={`/${a.slug}/`} class="text-sm" style="color: var(--color-text-muted);">{a.h1}</a></li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>
