---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SightCard from "../../components/SightCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import GetYourGuideWidget from "../../components/GetYourGuideWidget.astro";
import { sights } from "../../data/sights";
import { categories } from "../../data/categories";
import { getGygPlacement } from "../../data/gyg";
import { city } from "../../data/city";
import { indexUrl } from "../../i18n/config";
const sorted = [...sights].sort((a, b) => a.name.localeCompare(b.name, "de"));
---

<BaseLayout title={`Sehenswuerdigkeiten in ${city.name}`} description={`Alle ${sights.length} Sehenswürdigkeiten am Niederrhein: Archäologischer Park Xanten, Schwanenburg Kleve, Marienbasilika Kevelaer, Schloss Moyland, Wildgänse in den Rheinauen und mehr.`} alternateUrls={{ de: indexUrl("sights", "de"), en: indexUrl("sights", "en") }}>
  <div class="container-page py-12">
    <Breadcrumbs items={[{label: "Start", href: "/"}, {label: "Sehenswuerdigkeiten"}]} />
    <header class="mb-12">
      <p class="eyebrow mb-3">{sights.length} Eintraege</p>
      <h1 class="text-4xl sm:text-6xl font-medium tracking-tight mb-4" style="color: var(--color-text);">Sehenswürdigkeiten am Niederrhein</h1>
      <p class="text-lg max-w-3xl" style="color: var(--color-text-body);">
        Vom LVR-Archäologischen Park Xanten über die Schwanenburg Kleve, die Marienbasilika Kevelaer und Schloss Moyland bis zu den Rheinauen mit ihren Wildgänsen - alle Highlights des nördlichen Niederrheins.
      </p>
    </header>
    <div class="flex flex-wrap gap-2 mb-8">
      {categories.map((cat) => (
        <a href={`/kategorien/${cat.slug}/`} class="pill">{cat.name}</a>
      ))}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {sorted.map((s) => <SightCard sight={s} />)}
    </div>

    <section class="mt-12 pt-8 border-t" style="border-color: var(--color-border);">
      <h2 class="text-2xl font-semibold mb-4" style="color: var(--color-text);">Was kann man am Niederrhein machen?</h2>
      <p class="text-base max-w-3xl mb-5" style="color: var(--color-text-body);">
        Ideen für den Besuch - von Freizeitaktivitäten bis zum kompakten Tagesausflug:
      </p>
      <div class="flex flex-wrap gap-3">
        <a class="pill" href="/reiseplaner/">Touren & Reiseplaner am Niederrhein</a>
        <a class="pill" href="/spannende-aktivitaeten-in-duisburg-tagesausflug-oder-laengerer-aufenthalt/">Tagesausflug &amp; längerer Aufenthalt</a>
        <a class="pill" href="/reiseplaner/">Reiseplaner</a>
      </div>
    </section>

    <GetYourGuideWidget placement={getGygPlacement("page:sights-index")} />
  </div>
</BaseLayout>
