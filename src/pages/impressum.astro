---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { legal } from "../data/legal";
import { city } from "../data/city";
import { indexUrl } from "../i18n/config";
---

<BaseLayout title="Impressum" description="Impressum und Anbieterkennzeichnung gemaess Paragraph 5 TMG." noindex alternateUrls={{ de: indexUrl("imprint", "de"), en: indexUrl("imprint", "en") }}>
  <div class="container-page py-12 max-w-3xl">
    <Breadcrumbs items={[{ label: city.name, href: "/" }, { label: "Impressum" }]} />
    <h1 class="text-4xl sm:text-5xl font-medium tracking-tight mb-8" style="color: var(--color-text);">Impressum</h1>

    <div class="legal-prose">
      <h2>Informationen nach Paragraph 5 TMG</h2>
      <p>
        {legal.companyName}<br />
        {legal.registeredOffice.street}<br />
        {legal.registeredOffice.city} {legal.registeredOffice.postcode}<br />
        {legal.registeredOffice.country}
      </p>

      <h2>Kontakt</h2>
      <p>E-Mail: <a href={`mailto:${legal.email}`}>{legal.email}</a></p>
      <p style="font-size: 0.9rem; color: var(--color-text-muted);">{legal.natureOfBusiness}</p>

      <h2>Verantwortlich fuer den Inhalt nach Paragraph 18 Abs. 2 MStV</h2>
      <p>
        {legal.companyName}<br />
        {legal.registeredOffice.street}<br />
        {legal.registeredOffice.city} {legal.registeredOffice.postcode}, {legal.registeredOffice.country}
      </p>

      <h2>EU-Streitschlichtung</h2>
      <p>
        Die Europaeische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:
        <a href="https://ec.europa.eu/consumers/odr/" rel="noopener" target="_blank">https://ec.europa.eu/consumers/odr/</a>.
        Wir sind nicht verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.
      </p>

      <h2>Haftung fuer Inhalte</h2>
      <p>
        Die Inhalte dieser Website wurden mit groesster Sorgfalt erstellt. Fuer die Richtigkeit, Vollstaendigkeit
        und Aktualitaet der Inhalte koennen wir jedoch keine Gewaehr uebernehmen.
      </p>

      <h2>Haftung fuer Links</h2>
      <p>
        Unser Angebot enthaelt Links zu externen Websites Dritter, auf deren Inhalte wir keinen Einfluss haben.
        Fuer die Inhalte der verlinkten Seiten ist stets der jeweilige Anbieter verantwortlich.
      </p>

      <h2>Urheberrecht & Bilder</h2>
      <p>
        Bilder auf {city.name}-Interaktiv stammen, sofern nicht anders ausgewiesen, von Wikimedia Commons unter
        Creative-Commons-Lizenzen. Der jeweilige Autor und die Lizenz werden unter jedem Bild ausgewiesen.
      </p>

      <h2>Affiliate-Hinweis</h2>
      <p>
        Diese Website enthaelt Affiliate-Links, insbesondere zu Stay22 (Hotel-Buchungen via Booking.com) und
        GetYourGuide (Touren und Tickets). Wenn du ueber einen solchen Link buchst, erhalten wir eine Provision.
        Fuer dich aendert sich am Preis nichts. Die redaktionelle Auswahl erfolgt unabhaengig von Provisionen.
      </p>

      <p style="margin-top: 2rem; font-size: 0.875rem; color: var(--color-text-muted);">Stand: Mai 2026</p>
    </div>
  </div>
</BaseLayout>
