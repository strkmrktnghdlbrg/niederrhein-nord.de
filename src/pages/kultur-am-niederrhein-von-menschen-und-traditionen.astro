---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
const title = "Kultur am Niederrhein – von Menschen und Traditionen.";
const description = "Kultur am Niederrhein – von Menschen und Traditionen. — alles Wissenswerte rund um den nördlichen Niederrhein auf einen Blick.";
---
<BaseLayout title={title} description={description} alternateUrls={{ de: "/kultur-am-niederrhein-von-menschen-und-traditionen/" }}>
  <div class="container-page py-12 max-w-3xl">
    <Breadcrumbs items={[{ label: "Start", href: "/" }, { label: "Magazin", href: "/news/" }, { label: "Kultur am Niederrhein – von Menschen und Traditionen." }]} />
    <h1 class="text-4xl sm:text-5xl font-medium tracking-tight mb-6" style="color: var(--color-text);">Kultur am Niederrhein – von Menschen und Traditionen.</h1>
    <div class="legal-prose">
      <p>Kultur am Niederrhein – von Menschen und Traditionen. — alles Wissenswerte rund um den nördlichen Niederrhein auf einen Blick.</p>
      <h2>Was hat Niederrhein Nord zu bieten?</h2>
      <p>Was hat Niederrhein Nord zu bieten? — ein Thema rund um den nördlichen Niederrhein zwischen Rhein, Reichswald und niederländischer Grenze. Mehr Tipps und Ziele dazu findest du in unseren Sehenswürdigkeiten und Städte-Porträts.</p>
      <h2>Was kann man hier machen?</h2>
      <p>Was kann man hier machen? — ein Thema rund um den nördlichen Niederrhein zwischen Rhein, Reichswald und niederländischer Grenze. Mehr Tipps und Ziele dazu findest du in unseren Sehenswürdigkeiten und Städte-Porträts.</p>
      <h2>Niederrhein-nord</h2>
      <p>Niederrhein-nord — ein Thema rund um den nördlichen Niederrhein zwischen Rhein, Reichswald und niederländischer Grenze. Mehr Tipps und Ziele dazu findest du in unseren Sehenswürdigkeiten und Städte-Porträts.</p>
      <h2>Mehr am Niederrhein</h2>
      <ul>
        <li><a href="/sehenswuerdigkeiten/archaeologischer-park-xanten/">Archäologischer Park Xanten</a></li>
        <li><a href="/sehenswuerdigkeiten/schwanenburg-kleve/">Schwanenburg Kleve</a></li>
        <li><a href="/sehenswuerdigkeiten/marienbasilika-kevelaer/">Wallfahrt Kevelaer</a></li>
        <li><a href="/sehenswuerdigkeiten/schloss-moyland/">Schloss Moyland</a></li>
        <li><a href="/bezirke/">Städte &amp; Orte am Niederrhein</a></li>
        <li><a href="/sehenswuerdigkeiten/">Alle Sehenswürdigkeiten</a></li>
        <li><a href="/hotels/">Hotels am Niederrhein</a></li>
        <li><a href="/reiseplaner/">Reiseplaner &amp; Touren</a></li>
      </ul>
    </div>
  </div>
</BaseLayout>
