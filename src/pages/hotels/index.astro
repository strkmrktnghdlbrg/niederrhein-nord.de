---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HotelCard from "../../components/HotelCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Stay22TopHotels from "../../components/Stay22TopHotels.astro";
import { hotels } from "../../data/hotels";
import { city } from "../../data/city";
import { indexUrl } from "../../i18n/config";
const sorted = [...hotels].sort((a, b) => b.rating - a.rating);
---

<BaseLayout title={`Hotels in ${city.name}`} description={`Hotels am Niederrhein — von der Stadt-Pension bis zum 4-Sterne-Landhaus. Xanten, Kleve, Kevelaer, Reichswald und am Rhein.`} alternateUrls={{ de: indexUrl("hotels", "de"), en: indexUrl("hotels", "en") }}>
  <div class="container-page py-12">
    <Breadcrumbs items={[{label: "Start", href: "/"}, {label: "Hotels"}]} />
    <header class="mb-12">
      <p class="eyebrow mb-3">{hotels.length} Haeuser</p>
      <h1 class="text-4xl sm:text-6xl font-medium tracking-tight mb-4" style="color: var(--color-text);">Hotels am Niederrhein</h1>
      <p class="text-lg max-w-3xl" style="color: var(--color-text-body);">
        Vom Stadthotel in Xanten oder Kleve über das Landhaus am Reichswald bis zum Rheinhotel in Emmerich — geprüft, sortiert nach Gäste-Bewertung.
      </p>
    </header>

    <Stay22TopHotels limit={8} />

    <section class="mt-12 pt-8 border-t" style="border-color: var(--color-border);">
      <h2 class="text-2xl font-semibold mb-6" style="color: var(--color-text);">Unsere redaktionelle Hotel-Auswahl</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {sorted.map((h) => <HotelCard hotel={h} />)}
      </div>
    </section>

    <section class="mt-12 pt-8 border-t" style="border-color: var(--color-border);">
      <h2 class="text-2xl font-semibold mb-4" style="color: var(--color-text);">Hotels nach Stadtteil</h2>
      <p class="text-base max-w-3xl mb-5" style="color: var(--color-text-body);">
        Unterkünfte gezielt im richtigen Viertel finden — von der zentralen Innenstadt bis ans linke Rheinufer:
      </p>
      <div class="flex flex-wrap gap-3">
        <a class="pill" href="/bezirke/xanten/">Hotels in Xanten</a>
        <a class="pill" href="/bezirke/kleve/">Hotels in Kleve</a>
        <a class="pill" href="/hotels-ruhrort/">Hotels in Ruhrort &amp; Homberg</a>
        <a class="pill" href="/hotels-meiderich/">Hotels in Meiderich &amp; Beeck</a>
        <a class="pill" href="/hotels-rheinhausen/">Hotels in Rheinhausen</a>
      </div>
    </section>
  </div>
</BaseLayout>
