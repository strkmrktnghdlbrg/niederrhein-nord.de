---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RestaurantCard from "../../components/RestaurantCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { restaurants } from "../../data/restaurants";
import { city } from "../../data/city";
import { indexUrl } from "../../i18n/config";

const sorted = [...restaurants].sort((a, b) => a.name.localeCompare(b.name, "de"));
const cuisines = [...new Set(restaurants.map((r) => r.cuisine))].sort();
---

<BaseLayout title={`Restaurants in ${city.name}`} description="Restaurants am Niederrhein: niederrheinische Küche, Spargel & Erdbeeren, Hofcafés, Rheinblick - geprüft, sortiert nach Ort und Küche." alternateUrls={{ de: indexUrl("restaurants", "de"), en: indexUrl("restaurants", "en") }}>
  <div class="container-page py-12">
    <Breadcrumbs items={[{label: "Start", href: "/"}, {label: "Restaurants"}]} />
    <header class="mb-12">
      <p class="eyebrow mb-3">{restaurants.length} Adressen</p>
      <h1 class="text-4xl sm:text-6xl font-medium tracking-tight mb-4" style="color: var(--color-text);">Restaurants am Niederrhein</h1>
      <p class="text-lg max-w-3xl mb-6" style="color: var(--color-text-body);">
        Von der niederrheinischen Gaststube über das Hofcafé im Spargelland bis zum Fischrestaurant an der Rheinpromenade - die Gastronomie des Niederrheins in einer Übersicht.
      </p>
      <div class="flex flex-wrap gap-2">
        {cuisines.map((c) => <span class="pill">{c}</span>)}
      </div>
    </header>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {sorted.map((r) => <RestaurantCard restaurant={r} />)}
    </div>
  </div>
</BaseLayout>
