---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import HueGradient from "../../components/HueGradient.astro";
import GetYourGuideWidget from "../../components/GetYourGuideWidget.astro";
import { guides } from "../../data/guides";
import { getGygPlacement } from "../../data/gyg";
import { features } from "../../data/features";
import { indexUrl } from "../../i18n/config";

if (!features.reiseplaner.enabled) return Astro.redirect("/", 302);
---

<BaseLayout title="Reiseplaner" description="Reise-Guides für den Niederrhein: Xanten an einem Tag, Rad-Wochenende, Familienausflug — Tag-für-Tag-Routen mit Hotel- und Restaurant-Empfehlungen." alternateUrls={{ de: indexUrl("guides", "de"), en: indexUrl("guides", "en") }}>
  <div class="container-page py-12">
    <Breadcrumbs items={[{label: "Start", href: "/"}, {label: "Reiseplaner"}]} />
    <header class="mb-12">
      <p class="eyebrow mb-3">{guides.length} Routen</p>
      <h1 class="text-4xl sm:text-6xl font-medium tracking-tight mb-4" style="color: var(--color-text);">Niederrhein-Reiseplaner</h1>
      <p class="text-lg max-w-3xl" style="color: var(--color-text-body);">
        Fertige Tagespläne für den Niederrhein — Römerstadt Xanten, Rad-Wochenenden, Familienausflüge. Jeder Plan verweist auf konkrete Sehenswürdigkeiten, Restaurants und Hotels.
      </p>
    </header>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {guides.map((g) => (
        <a href={`/reiseplaner/${g.slug}/`} class="card group block">
          <div class="aspect-[4/3] overflow-hidden">
            <HueGradient hue={g.imageHue} label={g.title} />
          </div>
          <div class="p-5">
            <p class="text-xs font-semibold mb-2" style="color: var(--color-accent);">{g.duration} Tag{g.duration > 1 ? "e" : ""} &middot; {g.audience}</p>
            <h3 class="text-xl font-semibold mb-2" style="color: var(--color-text);">{g.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-body);">{g.shortDesc}</p>
          </div>
        </a>
      ))}
    </div>

    <GetYourGuideWidget placement={getGygPlacement("page:guides-index")} />
  </div>
</BaseLayout>
