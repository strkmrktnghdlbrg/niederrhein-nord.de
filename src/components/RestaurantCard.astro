---
import ContentImage from "./ContentImage.astro";
import type { Restaurant } from "../data/restaurants";
import { getDistrict } from "../data/districts";
import type { Locale } from "../i18n/config";
import { detailUrl } from "../i18n/config";
import { restaurantsEn } from "../i18n/en/restaurants";
import { districtsEn } from "../i18n/en/districts";

interface Props { restaurant: Restaurant; locale?: Locale }
const { restaurant, locale = "de" } = Astro.props;
const district = getDistrict(restaurant.district);

const en = locale === "en" ? restaurantsEn[restaurant.slug] : undefined;
const href = locale === "en" ? detailUrl("restaurants", en!.slug, "en") : `/restaurants/${restaurant.slug}/`;
const name = en?.name ?? restaurant.name;
const cuisine = en?.cuisine ?? restaurant.cuisine;
const shortDesc = en?.shortDesc ?? restaurant.shortDesc;
const districtName = locale === "en" ? (districtsEn[restaurant.district]?.name ?? district?.name ?? restaurant.district) : (district?.name ?? restaurant.district);
---

<a href={href} class="card group block">
  <div class="aspect-[4/3] relative overflow-hidden">
    <ContentImage
      imgKey={restaurant.imageKey}
      fallbackHue={restaurant.imageHue}
      fallbackLabel={name}
      imgClass="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
    <div class="absolute top-3 left-3">
      <span class="pill" style="background: rgba(8,9,10,0.85); backdrop-filter: blur(8px);">{cuisine}</span>
    </div>
    <div class="absolute top-3 right-3">
      <span class="pill font-bold" style="background: rgba(8,9,10,0.85); backdrop-filter: blur(8px);">{restaurant.priceLevel}</span>
    </div>
  </div>
  <div class="p-3">
    <p class="text-xs font-semibold mb-1" style="color: var(--color-text-muted);">{districtName}</p>
    <h3 class="text-base font-semibold leading-tight mb-2" style="color: var(--color-text);">{name}</h3>
    <p class="text-xs leading-relaxed line-clamp-2" style="color: var(--color-text-body);">{shortDesc}</p>
  </div>
</a>
