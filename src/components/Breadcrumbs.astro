---
import { city } from "../data/city";
import type { Locale } from "../i18n/config";

interface Crumb { label: string; href?: string }
interface Props { items: Crumb[]; locale?: Locale }
const { items } = Astro.props;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: item.label,
    ...(item.href && { item: `${city.domain}${item.href}` }),
  })),
};
---

<nav aria-label="Breadcrumb" class="text-xs mb-6">
  <ol class="flex flex-wrap items-center gap-1.5">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {item.href && i < items.length - 1 ? (
          <a href={item.href} style="color: var(--color-text-muted);">{item.label}</a>
        ) : (
          <span style="color: var(--color-text);" class="font-semibold">{item.label}</span>
        )}
        {i < items.length - 1 && <span style="color: var(--color-text-subtle);">/</span>}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline></script>
