---
/**
 * GetYourGuide Aktivitaeten-Widget (Dark).
 * Rendert eine query-basierte Liste von Touren/Tickets/Erlebnissen.
 * Das Partner-Script (pa.umd.production.min.js) wird global im BaseLayout geladen.
 * Graceful degradation: ohne aktivierte GYG-Config oder ohne Query rendert nichts.
 *
 * Verwendung (bevorzugt) ueber eine recherchierte Platzierung:
 *   <GetYourGuideWidget placement={getGygPlacement("sight:zkm")} />
 * oder direkt:
 *   <GetYourGuideWidget q="Duisburg" title="Erlebnisse in Duisburg" />
 */
import { affiliate, gygEnabled } from "../data/affiliate";
import type { GygPlacement } from "../data/gyg";

interface Props {
  placement?: GygPlacement;
  q?: string;
  title?: string;
  lead?: string;
  count?: number;
  cmp?: string;
}

const { placement, q, title, lead, count, cmp } = Astro.props;

const query = placement?.query ?? q;
const heading = placement?.title ?? title;
const sub = placement?.lead ?? lead;
const items = placement?.count ?? count ?? 4;
const campaign = cmp ?? placement?.key ?? "kr-portal";

// Bei expliziter Platzierung entscheidet deren show-Flag, sonst reicht eine Query.
const render = gygEnabled && !!query && (placement ? placement.show : true);
---

{render && (
  <section class="my-12 pt-8 border-t" style="border-color: var(--color-border);">
    <div class="mb-6 max-w-3xl">
      <p class="eyebrow mb-2">Touren &amp; Tickets &middot; GetYourGuide</p>
      {heading && (
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight mb-2" style="color: var(--color-text);">{heading}</h2>
      )}
      {sub && (
        <p class="text-base leading-relaxed" style="color: var(--color-text-body);">{sub}</p>
      )}
    </div>

    <div
      data-gyg-widget="activities"
      data-gyg-partner-id={affiliate.getYourGuide.partnerId}
      data-gyg-locale-code={affiliate.getYourGuide.locale}
      data-gyg-currency="EUR"
      data-gyg-number-of-items={String(items)}
      data-gyg-q={query}
      data-gyg-cmp={campaign}
    ></div>

    <p class="text-[11px] mt-4 leading-relaxed" style="color: var(--color-text-muted);">
      * Affiliate &mdash; Buchung laeuft ueber GetYourGuide. Bei Buchung ueber diese Links erhalten wir eine Provision, fuer dich entstehen keine Mehrkosten.
    </p>
  </section>
)}
