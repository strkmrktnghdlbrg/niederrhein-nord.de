---
/**
 * Stay22 Hotels in der Naehe (Dark).
 * Lat/lng-basierter Live-Block fuer Sight-/Hotel-/Bezirks-Detail-Seiten.
 * Build-Time-Fetch, graceful degradation ohne API-Key.
 */
import { searchAccommodations, type Stay22Accommodation } from "../lib/stay22";
import { affiliate } from "../data/affiliate";
import Stay22HotelCard from "./Stay22HotelCard.astro";

interface Props {
  lat: number;
  lng: number;
  near: string;
  radius?: number;
  limit?: number;
}

const { lat, lng, near, radius = 1800, limit = 4 } = Astro.props;
const lmaId = affiliate.stay22.lmaId;

let hotels: Stay22Accommodation[] | null = null;
try {
  hotels = await searchAccommodations({
    provider: "booking",
    lat,
    lng,
    radius,
    type: "hotel",
    minguestrating: 7.5,
    limit,
    currency: "EUR",
    lang: "de",
    aid: lmaId,
    campaign: lmaId,
  });
} catch (err) {
  console.error(`[Stay22NearbyHotels] Fetch-Fehler fuer ${near}:`, err);
}

const visible = hotels && hotels.length > 0 ? hotels.slice(0, limit) : [];
---

{visible.length > 0 && (
  <section class="my-12 pt-8 border-t" style="border-color: var(--color-border);">
    <div class="mb-6">
      <p class="eyebrow mb-2">Live von Stay22</p>
      <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight mb-2" style="color: var(--color-text);">
        Hotels in der Naehe von {near}
      </h2>
      <p class="text-base leading-relaxed" style="color: var(--color-text-body);">
        Aktuelle Preise und Verfuegbarkeit im Umkreis von {Math.round(radius / 100) * 100} m.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {visible.map((h) => <Stay22HotelCard hotel={h} showDistance />)}
    </div>

    <p class="text-[11px] mt-4 leading-relaxed" style="color: var(--color-text-muted);">
      * Sponsored - Buchung laeuft ueber Booking.com via Stay22-Affiliate. Fuer dich entstehen keine Mehrkosten.
    </p>
  </section>
)}
