---
/**
 * Stay22 Top-Hotels Live-Block (Dark).
 * Build-Time-Fetch der bestbewerteten Hotels via Stay22 Direct Travel API.
 * Graceful degradation: ohne Key oder leere Antwort rendert nichts.
 */
import { getTopHotels, type Stay22Accommodation } from "../lib/stay22";
import { affiliate } from "../data/affiliate";
import { city } from "../data/city";
import Stay22HotelCard from "./Stay22HotelCard.astro";

interface Props {
  address?: string;
  limit?: number;
  title?: string;
  lead?: string;
}

const {
  address = `${city.name}, Deutschland`,
  limit = 8,
  title = `Aktuell bestbewertete Hotels in ${city.name}`,
  lead = "Live von Booking.com - aktuelle Bewertungen und Preise, aktualisiert beim letzten Build.",
} = Astro.props;

let hotels: Stay22Accommodation[] | null = null;
try {
  hotels = await getTopHotels(address, affiliate.stay22.lmaId, { limit });
} catch (err) {
  console.error("[Stay22TopHotels] Build-Fetch-Fehler:", err);
  hotels = null;
}

const visible = hotels && hotels.length > 0 ? hotels.slice(0, limit) : [];
const buildTime = new Date().toLocaleDateString("de-DE", { year: "numeric", month: "long", day: "numeric" });
---

{visible.length > 0 && (
  <section class="my-12">
    {title ? (
      <div class="mb-6 max-w-3xl">
        <p class="eyebrow mb-2">Live von Stay22</p>
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight mb-2" style="color: var(--color-text);">{title}</h2>
        <p class="text-base leading-relaxed" style="color: var(--color-text-body);">{lead}</p>
      </div>
    ) : (
      <p class="text-sm mb-4" style="color: var(--color-text-body);">{lead}</p>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {visible.map((h) => <Stay22HotelCard hotel={h} />)}
    </div>

    <p class="text-[11px] mt-4 leading-relaxed" style="color: var(--color-text-muted);">
      * Sponsored - Buchung laeuft ueber Booking.com via Stay22-Affiliate. Stand: {buildTime}. Preise und Verfuegbarkeit aendern sich taeglich.
    </p>
  </section>
)}
