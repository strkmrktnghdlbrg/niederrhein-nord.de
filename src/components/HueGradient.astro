---
interface Props {
  hue: number;
  className?: string;
  label?: string;
}

const { hue, className = "", label } = Astro.props;
const safeHue = Math.min(Math.max(hue, 1), 5);
---

<div class={`relative w-full h-full ${className}`} style={`background: var(--hue-${safeHue});`}>
  {label && (
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <span class="text-white/90 text-sm font-bold tracking-wide drop-shadow text-center">{label}</span>
    </div>
  )}
</div>
